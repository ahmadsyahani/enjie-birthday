---
import '../styles/global.css';
import { Image } from 'astro:assets';

const images = import.meta.glob('../assets/photos/*.{jpeg,jpg,png,gif,webp}', { eager: true });
const imageList = Object.values(images);

const borderColors = ['border-pink-300', 'border-purple-300', 'border-blue-300', 'border-yellow-300', 'border-teal-300'];
const tapeColors = ['bg-pink-300/70', 'bg-yellow-300/70', 'bg-blue-300/70', 'bg-purple-300/70'];
const emojis = ['🎀', '✨', '🌸', '💖', '🦋', '💌', '🌷', '🌻'];
---
<html lang="id" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Happy Birthday Enjie! 💖</title>
    <link rel="icon" type="image/jpeg" href="/bear.jpg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style is:global>
      body {
        font-family: 'Plus Jakarta Sans', sans-serif;
      }
      
      .custom-scrollbar::-webkit-scrollbar { width: 6px; }
      .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
      .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(200, 200, 200, 0.5); border-radius: 10px; }
      .custom-scrollbar { -webkit-overflow-scrolling: touch; }
      .font-cursive { font-family: 'Dancing Script', cursive; }
      .glow-heart { filter: drop-shadow(0px 0px 8px rgba(255, 100, 150, 0.7)); }
      .no-scrollbar::-webkit-scrollbar { display: none; }
      .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
      
      @keyframes flowerBloom {
        0%, 100% { transform: scale(1) translateY(0); filter: brightness(1); }
        50% { transform: scale(1.15) translateY(-5px); filter: brightness(1.1); }
      }
      .flower-bloom { animation: flowerBloom 4s ease-in-out infinite; transform-origin: bottom center; }

      .gallery-item, #closure-card, #letter-content, #envelope-body {
        will-change: transform, opacity;
        transform: translateZ(0);
        backface-visibility: hidden;
      }
    </style>
  </head>
  <body class="antialiased relative selection:bg-pink-200 selection:text-pink-900 overflow-x-hidden bg-[#fafafa]">

    <button id="music-toggle" class="fixed bottom-6 right-6 z-[60] w-12 h-12 bg-white/70 backdrop-blur-md border border-white/50 rounded-full shadow-lg flex items-center justify-center text-xl transition-all duration-300 hover:scale-110 active:scale-95 opacity-0 pointer-events-none">
      <span id="music-icon">🔈</span>
    </button>
    <audio id="bg-music" src="/music/KasihPutih.mp3" loop></audio>

    <div class="fixed inset-0 pointer-events-none z-0 overflow-hidden opacity-60 text-3xl md:text-4xl">
      <div class="absolute top-12 left-6 animate-float">🧸</div>
      <div class="absolute top-20 right-[15%] animate-float" style="animation-delay: 2.2s;">🌻</div>
      <div class="absolute top-32 right-8 animate-float" style="animation-delay: 1s;">✨</div>
      <div class="absolute top-1/4 right-1/4 animate-float" style="animation-delay: 1.5s;">🎈</div>
      <div class="absolute top-1/3 left-4 animate-float" style="animation-delay: 2s;">💖</div>
      <div class="absolute top-[40%] left-[20%] animate-float" style="animation-delay: 3s;">🌻</div>
      <div class="absolute top-1/2 right-6 animate-float" style="animation-delay: 0.5s;">🐻</div>
      <div class="absolute bottom-1/3 left-10 animate-float" style="animation-delay: 1.2s;">🌸</div>
      <div class="absolute bottom-[20%] right-[30%] animate-float" style="animation-delay: 1.8s;">🌻</div>
      <div class="absolute bottom-1/4 right-12 animate-float" style="animation-delay: 2.5s;">🎀</div>
      <div class="absolute bottom-[10%] left-[15%] animate-float" style="animation-delay: 0.8s;">✨</div>
    </div>

    <div id="main-content">
      <section class="min-h-screen flex flex-col justify-center items-center relative z-10 px-6 hero-section">
        <div class="text-center w-full max-w-sm mt-10">
          <span class="text-6xl block mb-6 drop-shadow-sm hero-element">🎂</span>
          <h2 class="text-2xl text-gray-500 mb-1 font-medium hero-element font-heading tracking-wide">Happy Birthday,</h2>
          <h1 class="text-7xl text-pink-500 font-extrabold tracking-tighter mb-4 hero-element font-heading drop-shadow-sm">Enjie</h1>
          <p class="text-gray-600 text-lg mx-auto mb-10 leading-relaxed hero-element font-body px-4">Semoga hari-harimu secerah senyummu. Wishing you the best birthday Enjie</p>
          <div class="flex flex-col gap-4 justify-center hero-element w-full px-4 relative z-20">
            <button id="btn-kado" class="w-full bg-pink-500 text-white font-semibold py-4 rounded-full shadow-lg hover:shadow-pink-500/30 active:scale-95 transition-all duration-300">Buka Surat 💌</button>
            <a href="#gallery" class="w-full bg-white text-gray-700 border border-gray-200 font-semibold py-4 rounded-full hover:bg-gray-50 active:scale-95 transition-all duration-300">Lihat Scrapbook 👇</a>
          </div>
        </div>
      </section>

      <section id="gallery" class="relative z-10 bg-gradient-to-b from-pink-50 via-[#fffcf5] to-pink-100 rounded-t-[3rem] border-t border-pink-100 overflow-hidden shadow-[0_-20px_60px_rgba(255,192,203,0.15)]">
        <div class="absolute inset-0 opacity-20 pointer-events-none rounded-t-[3rem]" style="background-image: radial-gradient(#e2a3b7 1px, transparent 1px); background-size: 25px 25px;"></div>
        
        <div class="h-screen flex flex-col justify-center relative gallery-wrapper">
          <div class="container mx-auto px-6 relative z-20 mb-8">
            <div class="text-center gallery-header">
              <h2 class="text-4xl text-gray-800 font-extrabold mb-3 font-heading tracking-tight">Scrapbook Kita</h2>
              <p class="text-pink-500 font-bold animate-bounce mt-4 bg-white/80 backdrop-blur-sm inline-block px-5 py-2.5 rounded-full border border-pink-200 shadow-sm">↓ Terus Scroll ke Bawah ↓</p>
            </div>
          </div>

          <div class="flex gap-8 px-[10vw] w-max items-center py-10" id="gallery-content">
            {imageList.map((img: any, index: number) => {
              const bColor = borderColors[index % borderColors.length];
              const tColor = tapeColors[index % tapeColors.length];
              const hasSticker = index % 2 !== 0; 
              const sticker = emojis[index % emojis.length];
              const finalRot = (index % 2 === 0 ? -1 : 1) * (Math.random() * 4 + 2);
              
              return (
                <div class={`gallery-item w-[260px] md:w-[320px] shrink-0 bg-white p-2 pb-6 rounded-sm shadow-xl relative border-2 ${bColor}`} data-rot={finalRot}>
                  <div class={`absolute -top-3 left-1/2 -translate-x-1/2 w-12 h-6 ${tColor} backdrop-blur-sm shadow-sm z-20 transform -rotate-3`}></div>
                  <div class="w-full aspect-[4/5] overflow-hidden rounded-sm bg-gray-50 border border-gray-200">
                    <Image src={img.default} alt="Momen" width={400} height={500} format="avif" class="w-full h-full object-cover brightness-110 contrast-105 saturate-105" />
                  </div>
                  {hasSticker && <div class="absolute -bottom-4 -right-4 text-4xl z-30 drop-shadow-md transform rotate-12">{sticker}</div>}
                </div>
              );
            })}
          </div>
        </div>
      </section>

      <section class="min-h-[70vh] flex flex-col justify-center items-center relative z-10 px-4 md:px-6 bg-pink-100/50">
        <div class="relative text-center w-[90%] max-w-lg bg-white/80 backdrop-blur-md px-6 pb-8 pt-12 md:px-12 md:pb-12 md:pt-16 rounded-[2rem] shadow-xl border border-white will-animate" id="closure-card">
          
          <div id="sweet-message-popup" class="absolute -top-16 left-1/2 -translate-x-1/2 w-11/12 md:w-full bg-white px-6 py-4 rounded-2xl shadow-[0_10px_40px_rgba(255,105,180,0.2)] border-2 border-pink-200 opacity-0 scale-50 pointer-events-none transition-all duration-500 ease-out z-50 flex flex-col items-center gap-2">
            <span class="text-3xl animate-bounce">🎀</span>
            <p class="font-body text-pink-600 font-medium text-sm md:text-base leading-relaxed">
              "Terima kasih sudah lahir ke dunia ini dan jadi bagian terindah di ceritaku."<br>
              I love you, Sayangg 💖
            </p>
          </div>

          <div class="text-3xl mb-4">💖🙏</div>
          <h2 class="font-heading text-3xl text-pink-600 font-medium mb-4 tracking-tight">A Birthday Wish For You</h2>
          <p class="text-gray-600 font-body text-sm leading-relaxed mb-8 px-2 justify">
            Harapanku buat kamu, semoga tahun ini penuh dengan hal-hal baik, tawa yang lepas, dan mimpi-mimpi yang jadi nyata.<br><br>
            Aku akan selalu ada buat dukung kamu, di setiap langkah kamu.<br><br>
            Stay happy, Stay healthy, My Enjie💖🐻.
          </p>
          
          <button id="btn-aamiin" class="bg-gradient-to-r from-purple-400 to-pink-500 text-white font-bold py-3 px-8 rounded-full shadow-lg hover:scale-105 active:scale-95 transition-all">
            Bilang "Aamiin" 💌
          </button>
        </div>
      </section>

      <footer class="relative z-10 pt-16 pb-12 bg-gradient-to-b from-pink-100 to-[#ffe4e6] text-center overflow-hidden border-t border-pink-200">
        <div class="absolute bottom-0 left-0 w-full flex justify-around px-2 md:px-10 pointer-events-none opacity-80 z-0 items-end">
          <div class="text-4xl md:text-8xl flower-bloom" style="animation-delay: 0s;">🌻</div>
          <div class="text-4xl md:text-8xl flower-bloom" style="animation-delay: 1.5s;">🌷</div>
          <div class="text-4xl md:text-8xl flower-bloom" style="animation-delay: 0.8s;">🌸</div>
          <div class="text-4xl md:text-8xl flower-bloom" style="animation-delay: 2.2s;">🌺</div>
          <div class="text-4xl md:text-8xl flower-bloom" style="animation-delay: 0.5s;">🌸</div>
          <div class="text-4xl md:text-8xl flower-bloom" style="animation-delay: 1.8s;">🌷</div>
          <div class="text-4xl md:text-8xl flower-bloom transform -scale-x-100" style="animation-delay: 1.2s;">🌻</div>
        </div>
        <div class="relative z-10 bg-white/90 backdrop-blur-md inline-block px-8 py-4 rounded-full shadow-md border border-pink-200 mb-6 mt-4">
          <p class="text-gray-500 font-body text-sm font-medium tracking-wide">
            Made with <span class="text-pink-500 animate-pulse inline-block mx-1">💖</span> by <span class="font-bold text-pink-500">Ahsya</span> for <span class="font-bold text-pink-500">Enjie</span>
          </p>
        </div>
      </footer>
    </div>

    <div id="modal-surprise" class="fixed inset-0 z-50 flex flex-col justify-center items-center opacity-0 pointer-events-none selection:bg-pink-100 selection:text-pink-900">
      <div id="modal-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm opacity-0"></div>
      
      <div class="absolute w-[300px] h-[200px] bg-[#fffcf5] p-2 rounded-xl border-4 border-[#e6dbcc] overflow-hidden" id="envelope-body" style="opacity: 0; transform: translateY(50px) scale(0.9);">
        <div class="absolute inset-0 opacity-20 pointer-events-none" style="background-image: radial-gradient(#d1c5b4 1px, transparent 1px); background-size: 20px 20px;"></div>
        <div class="absolute top-0 left-0 w-full h-0 border-l-[150px] border-l-transparent border-r-[150px] border-r-transparent border-t-[100px] border-t-[#e6dbcc] transform-origin-top z-30" id="envelope-flap"></div>
        <div class="absolute bottom-0 left-0 w-full h-full border-l-[150px] border-l-transparent border-r-[150px] border-r-transparent border-b-[100px] border-b-[#e6dbcc] z-20"></div>
        <div class="absolute inset-0 z-10 p-6 flex flex-col justify-center items-center text-center">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 w-16 h-8 bg-blue-300/70 backdrop-blur-sm transform -rotate-2 rounded-sm"><span class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 text-white text-lg">💌</span></div>
          <div class="text-6xl text-purple-600 mb-2 mt-4">🧸</div>
          <h3 class="font-heading text-2xl text-pink-500 font-bold mb-1">To: Enjie</h3>
        </div>
      </div>

      <div class="relative w-[90vw] max-w-[450px] h-[80vh] bg-[#fdfbf8] shadow-2xl z-40 rounded-xl flex flex-col font-body text-gray-800 opacity-0 overflow-hidden" id="letter-content" style="transform: translateY(0px) scale(0.8);">
        
        <div class="absolute top-0 left-0 h-2 w-full bg-gradient-to-r from-pink-300 via-purple-300 to-blue-300 z-10"></div>
        <div class="absolute inset-0 opacity-40 pointer-events-none z-0" style="background-image: radial-gradient(#cbd5e1 1px, transparent 1px); background-size: 20px 20px;"></div>

        <div id="letter-text-container" class="flex-1 overflow-y-auto custom-scrollbar px-8 md:px-10 py-10 pb-32 relative z-10" data-lenis-prevent>
          <h3 class="font-heading text-3xl md:text-4xl text-pink-500 font-bold mb-6 drop-shadow-sm tracking-tight">Dear Enjie,</h3>
          
          <div class="leading-loose text-sm space-y-5 font-medium text-gray-800 text-justify pr-2">
            <span id="letter-text-source" class="hidden">
            Selamat ulang tahun yang ke-19, Sayang! 💖<br><br>

            Di usiamu yang baru ini, aku cuma mau bilang kalau kamu adalah hal terindah dan termanis yang pernah ada. Aku ngeliat kamu tumbuh dan berproses setiap harinya, bikin aku sadar betapa beruntungnya aku bisa ketemu kamu.<br><br>

            Kamu bukan cuma makin dewasa, tapi makin hebat dan luar biasa di mataku. Makasih ya sudah jadi versi terbaik dirimu, dan makasih sudah mau berbagi banyak momen lucu, sedih, sampai bahagia bareng, hehe.<br><br>

            Teruslah bersinar dengan caramu sendiri ya. Kejar semua mimpi yang kamu ingin dan jangan pernah ragu untuk melangkah, karena aku akan selalu ada di barisan paling depan buat mendukung dan menemani kamu sekarang.<br><br>

            Jangan ragu buat minta tolong ke aku, aku juga seneng kok kamu minta tolong ke aku. Kamu jangan merasa gaenak sama aku yaa cantik.<br><br>

            Semoga ditahun ini dapat membawa lebih banyak kabar bahagia, banyak tawa, datang berkah, dan kejutan manis buat kamu.<br><br>
             
            I love you so much, Enjie💖🐻
            </span>
            <p id="letter-text-target" class="pb-2"></p> 
          </div>

          <div id="letter-photos" class="mt-12 relative h-[540px] opacity-0 translate-y-10 transition-all duration-1000 ease-out w-full hidden">
            
            {images['../assets/photos/foto5.webp'] && (
              <div class="absolute top-4 left-0 w-[45%] rotate-[-4deg] shadow-lg border-[6px] border-white bg-white z-10 hover:z-50 hover:scale-105 transition-all duration-300">
                <div class="absolute -top-3 -left-3 w-10 h-6 bg-[#e6ccb2]/80 backdrop-blur-sm transform rotate-[-20deg]"></div>
                <Image 
                  src={images['../assets/photos/foto5.webp'].default} 
                  alt="Memories" 
                  width={413} 
                  height={1230} 
                  class="w-full h-auto object-cover rounded-sm" 
                />
              </div>
            )}
            
            {images['../assets/photos/foto6.webp'] && (
              <div class="absolute top-0 right-0 w-[48%] rotate-[6deg] shadow-xl border-[6px] border-white bg-white z-20 hover:z-50 hover:scale-105 transition-all duration-300">
                <Image src={images['../assets/photos/foto6.webp'].default} alt="Memories" width={200} height={200} class="w-full object-cover aspect-square" />
              </div>
            )}

            {images['../assets/photos/foto1.webp'] && (
              <div class="absolute top-[160px] right-[4%] w-[46%] rotate-[-3deg] shadow-xl border-[6px] border-white bg-white z-30 hover:z-50 hover:scale-105 transition-all duration-300">
                <div class="absolute -left-4 top-1/2 w-12 h-6 bg-pink-200/80 backdrop-blur-sm transform rotate-[-15deg]"></div>
                <Image src={images['../assets/photos/foto1.webp'].default} alt="Memories" width={200} height={200} class="w-full object-cover aspect-square" />
              </div>
            )}
            
            {images['../assets/photos/foto3.webp'] && (
              <div class="absolute top-[320px] right-0 w-[48%] rotate-[5deg] shadow-xl border-[6px] border-white bg-white z-40 hover:z-50 hover:scale-105 transition-all duration-300">
                <div class="absolute -bottom-3 -right-4 w-12 h-6 bg-orange-200/80 backdrop-blur-sm transform rotate-[25deg]"></div>
                <Image src={images['../assets/photos/foto3.webp'].default} alt="Memories" width={200} height={200} class="w-full object-cover aspect-square" />
              </div>
            )}
          </div>

          <div id="signature-area" class="mt-14 flex flex-wrap items-center justify-center opacity-0 translate-y-6 transition-all duration-1000 ease-out hidden pb-12">
            <h4 class="font-cursive text-4xl text-gray-900 tracking-normal drop-shadow-sm">With all my love, Ahsya 💖🌻</h4>
          </div>
        </div>

        <div class="absolute bottom-0 w-full p-4 bg-gradient-to-t from-[#fdfbf8] via-[#fdfbf8]/90 to-transparent z-20 flex justify-end pointer-events-none">
          <button id="modal-close" class="pointer-events-auto text-sm font-bold py-2.5 px-6 bg-white border border-gray-200 text-gray-600 rounded-full shadow-[0_4px_15px_rgba(0,0,0,0.05)] hover:text-pink-500 hover:border-pink-200 hover:shadow-pink-200 transition-all flex items-center justify-center">
            Tutup ✕
          </button>
        </div>
      </div>
    </div>

    <script>
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";
      import Lenis from "lenis";
      import confetti from 'canvas-confetti';

      gsap.registerPlugin(ScrollTrigger);

      const lenis = new Lenis({ 
        duration: 1.2, 
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)), 
        smoothWheel: true,
        touchMultiplier: 2, 
      });

      const bgMusic = document.getElementById('bg-music') as HTMLAudioElement;
      const musicToggle = document.getElementById('music-toggle');
      const musicIcon = document.getElementById('music-icon');
      let isPlaying = false;

      function updateMusicUI() {
        if (musicIcon) musicIcon.innerHTML = isPlaying ? "🔊" : "🔈";
        musicToggle?.classList.toggle('animate-[spin_4s_linear_infinite]', isPlaying);
      }

      musicToggle?.addEventListener('click', () => {
        isPlaying ? bgMusic.pause() : bgMusic.play();
        isPlaying = !isPlaying;
        updateMusicUI();
      });

      // Animasi Element Biasa
      gsap.from(".hero-element", { duration: 1.2, y: 40, opacity: 0, stagger: 0.15, ease: "power3.out", delay: 0.2 });
      gsap.from("#closure-card", {
        scrollTrigger: { trigger: "#closure-card", start: "top 80%" },
        duration: 1, y: 50, opacity: 0, scale: 0.9, ease: "back.out(1.5)"
      });
      
      let galleryWrapper = document.querySelector('.gallery-wrapper');
      let galleryContent = document.getElementById('gallery-content');

      if (galleryContent) {
        let scrollTween = gsap.to(galleryContent, {
          x: () => -(galleryContent.scrollWidth - window.innerWidth),
          ease: "none",
          scrollTrigger: {
            trigger: "#gallery",
            start: "top top",
            end: () => "+=" + (galleryContent.scrollWidth),
            pin: true,
            scrub: 1,
            invalidateOnRefresh: true,
          }
        });

        document.querySelectorAll('.gallery-item').forEach((item) => {
          const finalRot = parseFloat(item.getAttribute('data-rot') || '0');
          gsap.fromTo(item, 
            { y: 100, opacity: 0, rotation: gsap.utils.random(-30, 30) }, 
            { 
              y: 0, opacity: 1, rotation: finalRot, ease: "back.out(1.2)",
              scrollTrigger: {
                trigger: item,
                containerAnimation: scrollTween,
                start: "left 85%", 
                toggleActions: "play none none reverse"
              } 
            }
          );
        });
      }

      const btnKado = document.getElementById('btn-kado');
      const modal = document.getElementById('modal-surprise');
      const backdrop = document.getElementById('modal-backdrop');
      const envelopeBody = document.getElementById('envelope-body');
      const envelopeFlap = document.getElementById('envelope-flap');
      const letterContent = document.getElementById('letter-content');
      const textSource = document.getElementById('letter-text-source');
      const textTarget = document.getElementById('letter-text-target');
      const letterContainer = document.getElementById('letter-text-container');
      const closeBtn = document.getElementById('modal-close');
      const btnAamiin = document.getElementById('btn-aamiin');
      const popupMsg = document.getElementById('sweet-message-popup');

      let typingInterval: any = null;

      function fireConfetti() {
        confetti({ particleCount: 150, spread: 70, origin: { y: 0.7 }, zIndex: 100 });
        setTimeout(() => {
          confetti({ particleCount: 50, angle: 60, spread: 55, origin: { x: 0 }, zIndex: 100, shapes: ['emoji'], emoji: { emoji: '💖' } });
          confetti({ particleCount: 50, angle: 120, spread: 55, origin: { x: 1 }, zIndex: 100, shapes: ['emoji'], emoji: { emoji: '✨' } });
        }, 300);
      }

      function startTyping() {
        if (!textTarget || !textSource || !letterContainer) return;
        textTarget.innerHTML = "";
        const fullText = textSource.innerHTML.trim();
        let i = 0;
        
        if (typingInterval) clearInterval(typingInterval);
        
        typingInterval = setInterval(() => {
          if (i < fullText.length) {
            if (fullText.substring(i, i + 4) === '<br>') {
              textTarget.innerHTML += '<br>';
              i += 4;
            } else {
              textTarget.innerHTML += fullText.charAt(i);
              i++;
            }
            letterContainer.scrollTop = letterContainer.scrollHeight;
          } else {
            clearInterval(typingInterval);
            const photos = document.getElementById("letter-photos");
            const signature = document.getElementById("signature-area");
            
            if(photos) {
              photos.classList.remove("hidden");
              void photos.offsetWidth; 
              photos.classList.remove("opacity-0", "translate-y-10");
            }
            if(signature) {
              signature.classList.remove("hidden");
              setTimeout(() => {
                signature.classList.remove("opacity-0", "translate-y-6");
                letterContainer.scrollTo({ top: letterContainer.scrollHeight, behavior: 'smooth' });
              }, 400);
            }
          }
        }, 40);
      }

      function openSurpriseModal() {
        lenis.stop();
        const tl = gsap.timeline();

        tl.to(modal, { duration: 0.1, opacity: 1, pointerEvents: "auto" });
        tl.to(backdrop, { duration: 0.4, opacity: 1 });
        tl.to(envelopeBody, { duration: 0.6, scale: 1, y: 0, opacity: 1, ease: "back.out(1.5)" });
        tl.to(envelopeFlap, { duration: 0.5, rotationX: -180, ease: "power2.inOut", delay: 0.2 });
        tl.to(envelopeBody, { duration: 0.4, opacity: 0, scale: 0.8 }, "+=0.1");
        tl.to(letterContent, { duration: 0.7, opacity: 1, scale: 1, ease: "power3.out" }, "-=0.3");

        tl.call(startTyping, [], "+=0.2");
      }

      function closeModal() {
        if (typingInterval) clearInterval(typingInterval);
        lenis.start(); 
        const tl = gsap.timeline();
        tl.to(modal, { duration: 0.4, opacity: 0, pointerEvents: "none", ease: "power2.in" });
        tl.set(backdrop, { opacity: 0 });
        tl.set([letterContent, envelopeBody], { clearProps: "all" });
        tl.set(envelopeFlap, { rotationX: 0 });
        if(textTarget) textTarget.innerHTML = "";
        
        const photos = document.getElementById("letter-photos");
        const signature = document.getElementById("signature-area");
        if(photos) { photos.classList.add("hidden", "opacity-0", "translate-y-10"); }
        if(signature) { signature.classList.add("hidden", "opacity-0", "translate-y-6"); }
      }

      btnKado?.addEventListener('click', () => {
        if (!isPlaying) {
          bgMusic.play().then(() => {
            isPlaying = true;
            updateMusicUI();
            gsap.to(musicToggle, { opacity: 1, pointerEvents: "auto", duration: 0.5 });
          }).catch(e => console.log("Audio blocked:", e));
        }
        fireConfetti();
        setTimeout(openSurpriseModal, 500);
      });

      // LOGIKA TOMBOL AAMIIN (Munculin Pop Up)
      btnAamiin?.addEventListener('click', () => {
        // Tembakin confeti kecil
        confetti({ particleCount: 50, spread: 40, origin: { y: 0.8 }, zIndex: 100 });
        
        if (popupMsg) {
          // Munculin popup
          popupMsg.classList.remove('opacity-0', 'scale-50', 'pointer-events-none');
          popupMsg.classList.add('opacity-100', 'scale-100');
          
          // Sembunyiin lagi otomatis setelah 4 detik
          setTimeout(() => {
            popupMsg.classList.remove('opacity-100', 'scale-100');
            popupMsg.classList.add('opacity-0', 'scale-50', 'pointer-events-none');
          }, 4000);
        }
      });

      closeBtn?.addEventListener('click', closeModal);
      backdrop?.addEventListener('click', closeModal);
    </script>
  </body>
</html>